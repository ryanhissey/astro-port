---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Badge from '../components/Badge.astro';
import { SITE_TITLE, SITE_DESCRIPTION, GITHUB_URL, SITE_EMAIL } from '../consts';
import avatarImage from '../assets/me.webp';
---

<BaseLayout title={`About - ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
	<Container class="pt-16 sm:pt-24">
		<div class="grid grid-cols-1 gap-y-16 lg:grid-cols-2 lg:grid-rows-[auto_1fr] lg:gap-y-12">
			<div class="lg:pl-20">
				<div class="max-w-xs px-2.5 lg:max-w-none">
					<Image
						src={avatarImage}
						alt="Ryan Hissey"
						width={400}
						height={400}
						loading="eager"
						fetchpriority="high"
						class="aspect-square rotate-3 rounded-2xl object-cover shadow-xl shadow-brand-800/50 ring-1 ring-brand-500/20"
					/>
				</div>
			</div>
			<div class="lg:order-first lg:row-span-2">
				<h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
					Hi, I'm Ryan Hissey. A backend software engineer from Stone, Staffordshire.
				</h1>
				<div class="mt-6 space-y-6 text-base text-brand-100/80">
					<p>
						I'm a PHP backend developer specialising in Laravel applications and e-commerce
						platforms, with extensive Magento 2 experience. Currently I work at Hyv&auml;, where I
						build core products including checkout integrations for payment providers, develop
						enterprise features, and create certification assessment materials.
					</p>
					<p>
						Before Hyv&auml;, I worked across the Magento ecosystem at companies including Vitl,
						Etika Finance UK, and Aware Digital. I've built headless e-commerce APIs, developed
						a TypeScript-based Shopify payment app, contributed to Hyv&auml; Themes, and managed
						hosting infrastructure for over 200 websites at Netbiz Group.
					</p>
					<p>
						I studied Computer Science at Keele University, where my dissertation focused on
						building a live lecture feedback system. I hold certifications as a Hyv&auml; Certified
						Professional Developer, Hyv&auml; Certified Associate Developer, and Adobe Certified
						Professional in Adobe Commerce Development.
					</p>
					<p>
						Outside of client work, I enjoy contributing to open source and exploring new backend
						technologies. I've published packages on Packagist and I'm always interested in diverse
						backend challenges beyond the ecommerce space.
					</p>
				</div>
			</div>
			<div class="lg:pl-20">
				<div class="flex flex-col gap-4">
					<a
						href={GITHUB_URL}
						target="_blank"
						rel="noopener noreferrer"
						class="group flex items-center gap-3 text-sm font-medium text-brand-100/70 transition hover:text-brand-200"
					>
						<svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 flex-none fill-brand-100/50 transition group-hover:fill-brand-200">
							<path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.475 2 2 6.588 2 12.253c0 4.537 2.862 8.369 6.838 9.727.5.09.687-.218.687-.487 0-.243-.013-1.05-.013-1.91C7 20.059 6.35 18.957 6.15 18.38c-.113-.295-.6-1.205-1.025-1.448-.35-.192-.85-.667-.013-.68.788-.012 1.35.744 1.538 1.051.9 1.551 2.338 1.116 2.912.846.088-.666.35-1.115.638-1.371-2.225-.256-4.55-1.14-4.55-5.062 0-1.115.387-2.038 1.025-2.756-.1-.256-.45-1.307.1-2.717 0 0 .837-.269 2.75 1.051.8-.23 1.65-.346 2.5-.346.85 0 1.7.115 2.5.346 1.912-1.333 2.75-1.05 2.75-1.05.55 1.409.2 2.46.1 2.716.637.718 1.025 1.628 1.025 2.756 0 3.934-2.337 4.806-4.562 5.062.362.32.675.936.675 1.897 0 1.371-.013 2.473-.013 2.82 0 .269.188.589.688.487a10.036 10.036 0 0 0 4.932-3.74A10.447 10.447 0 0 0 22 12.253C22 6.588 17.525 2 12 2Z" />
						</svg>
						Follow on GitHub
					</a>
					<a
						href={`mailto:${SITE_EMAIL}`}
						class="group flex items-center gap-3 text-sm font-medium text-brand-100/70 transition hover:text-brand-200"
					>
						<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="h-6 w-6 flex-none stroke-brand-100/50 transition group-hover:stroke-brand-200">
							<path d="M2.75 7.75a3 3 0 0 1 3-3h12.5a3 3 0 0 1 3 3v8.5a3 3 0 0 1-3 3H5.75a3 3 0 0 1-3-3v-8.5Z" />
							<path d="m4 6 6.024 5.479a2.915 2.915 0 0 0 3.952 0L20 6" />
						</svg>
						{SITE_EMAIL}
					</a>
				</div>
			</div>
		</div>
	</Container>

	<!-- Uses Section -->
	<Container class="mt-16 sm:mt-24">
		<div class="max-w-2xl">
			<h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
				What I use
			</h2>
			<p class="mt-4 text-base text-brand-100/80">
				Software, hardware and tools I use on a daily basis to get things done. Updated occasionally as things change.
			</p>
		</div>

		<div class="mt-12 space-y-8">
			<!-- Hardware -->
			<section class="rounded-2xl border border-brand-600/50 bg-brand-700/50 backdrop-blur-sm p-6 sm:p-8">
				<div class="flex items-center gap-3 text-sm font-semibold text-brand-50">
					<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" class="h-6 w-6 stroke-brand-200">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25A2.25 2.25 0 0 1 5.25 3h13.5A2.25 2.25 0 0 1 21 5.25Z" />
					</svg>
					Hardware
				</div>
				<div class="mt-4 flex flex-wrap gap-2">
					<Badge>MacBook Pro 16" (M1 Pro)</Badge>
					<Badge>Alienware 34 AW3423DWF OLED Monitor</Badge>
					<Badge>Logitech MX Master 3</Badge>
					<Badge>Apple Magic Keyboard</Badge>
				</div>
			</section>

			<!-- Development -->
			<section class="rounded-2xl border border-brand-600/50 bg-brand-700/50 backdrop-blur-sm p-6 sm:p-8">
				<div class="flex items-center gap-3 text-sm font-semibold text-brand-50">
					<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" class="h-6 w-6 stroke-brand-200">
						<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />
					</svg>
					Development
				</div>
				<div class="mt-4 flex flex-wrap gap-2">
					<Badge>PhpStorm</Badge>
					<Badge>TablePlus</Badge>
					<Badge>iTerm2</Badge>
					<Badge>Docker</Badge>
				</div>
			</section>

			<!-- Productivity -->
			<section class="rounded-2xl border border-brand-600/50 bg-brand-700/50 backdrop-blur-sm p-6 sm:p-8">
				<div class="flex items-center gap-3 text-sm font-semibold text-brand-50">
					<svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" class="h-6 w-6 stroke-brand-200">
						<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
					</svg>
					Productivity
				</div>
				<div class="mt-4 flex flex-wrap gap-2">
					<Badge>1Password</Badge>
				</div>
			</section>
		</div>
	</Container>
</BaseLayout>
