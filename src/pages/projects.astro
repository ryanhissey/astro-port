---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { SITE_TITLE } from '../consts';

const projects = await getCollection('projects');
---

<BaseLayout title={`Projects - ${SITE_TITLE}`} description="Things I've built.">
	<Container class="pt-16 sm:pt-24">
		<div class="max-w-2xl">
			<h1 class="text-4xl font-bold tracking-tight text-white sm:text-5xl">
				Things I've built.
			</h1>
			<p class="mt-6 text-base text-brand-100/80">
				Ready to take a sneak peek at my work? Go ahead and explore my portfolio.
			</p>
		</div>
		<div class="mt-12 grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3">
			{projects.map((project) => (
				<ProjectCard
					title={project.data.title}
					description={project.data.description}
					url={project.data.url}
					tags={project.data.tags}
				/>
			))}
		</div>
	</Container>
</BaseLayout>
