---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body class="bg-brand-800 text-brand-50 antialiased overflow-x-hidden">
		<!-- Background accents -->
		<div class="pointer-events-none fixed inset-0 z-0 overflow-hidden" aria-hidden="true">
			<!-- Grid pattern -->
			<div class="absolute inset-0 bg-grid opacity-[0.03]"></div>

			<!-- Primary glow — top right, warm purple-indigo -->
			<div class="bg-glow-primary absolute -top-32 -right-20 h-[700px] w-[500px] rotate-12 rounded-full opacity-20 blur-[130px]"></div>

			<!-- Secondary glow — mid-left, cooler blue with a hint of cyan -->
			<div class="bg-glow-secondary absolute top-[35%] -left-32 h-[550px] w-[400px] -rotate-6 rounded-full opacity-15 blur-[120px]"></div>

			<!-- Accent glow — bottom center-right, subtle magenta tint -->
			<div class="bg-glow-accent absolute -bottom-24 right-[10%] h-[450px] w-[450px] rotate-45 rounded-full opacity-10 blur-[110px]"></div>

			<!-- Small highlight — top left, faint warm spot -->
			<div class="bg-glow-highlight absolute top-[15%] left-[10%] h-[250px] w-[250px] rounded-full opacity-[0.07] blur-[80px]"></div>
		</div>

		<div class="relative z-10 flex min-h-screen flex-col">
			<Header />
			<main class="mt-16 flex-1">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
