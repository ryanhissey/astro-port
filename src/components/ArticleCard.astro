---
import FormattedDate from './FormattedDate.astro';

interface Props {
	title: string;
	date: Date;
	description: string;
	slug: string;
}

const { title, date, description, slug } = Astro.props;
---

<article class="group relative flex flex-col gap-2 rounded-2xl border border-brand-600/50 bg-brand-700/50 backdrop-blur-sm p-5">
	<div class="absolute -inset-px z-0 rounded-2xl bg-brand-600/30 opacity-0 transition group-hover:opacity-100"></div>
	<div class="relative z-10">
		<div class="flex items-center gap-3 text-sm text-brand-100/60">
			<span class="h-4 w-0.5 rounded-full bg-brand-300"></span>
			<FormattedDate date={date} />
		</div>
		<h3 class="mt-2 text-base font-semibold tracking-tight text-brand-50">
			{title}
		</h3>
		<p class="mt-2 text-sm text-brand-100/70 line-clamp-3">
			{description}
		</p>
		<a href={`/articles/${slug}/`} class="relative z-10 mt-3 inline-flex items-center gap-1 text-sm font-medium text-brand-200">
			Read article
			<svg viewBox="0 0 16 16" fill="none" aria-hidden="true" class="h-4 w-4 stroke-current">
				<path d="M6.75 5.75 9.25 8l-2.5 2.25" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
			</svg>
			<span class="absolute -inset-0 z-20 rounded-2xl"></span>
		</a>
	</div>
</article>
