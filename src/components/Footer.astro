---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer class="border-t border-brand-600/40 mt-24">
	<div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-6 px-4 py-10 sm:flex-row sm:px-6 lg:px-8">
		<nav class="flex gap-6">
			<a href="/" class="text-sm text-brand-100/60 transition hover:text-brand-50">Home</a>
			<a href="/about" class="text-sm text-brand-100/60 transition hover:text-brand-50">About</a>
			<a href="/articles" class="text-sm text-brand-100/60 transition hover:text-brand-50">Articles</a>
			<a href="/projects" class="text-sm text-brand-100/60 transition hover:text-brand-50">Projects</a>
		</nav>
		<p class="text-sm text-brand-100/40">
			&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
		</p>
	</div>
</footer>
