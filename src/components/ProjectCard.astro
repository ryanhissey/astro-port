---
import Badge from './Badge.astro';

interface Props {
	title: string;
	description: string;
	url?: string;
	tags?: string[];
}

const { title, description, url, tags = [] } = Astro.props;
const linkHostname = url ? new URL(url).hostname.replace(/^www\./, '') : null;
---

<div class="group relative flex flex-col rounded-2xl border border-brand-600/50 bg-brand-700/50 backdrop-blur-sm p-6 transition hover:border-brand-500/50">
	<div class="flex items-center gap-3">
		<div class="flex h-10 w-10 items-center justify-center rounded-full bg-brand-600/60 ring-1 ring-brand-500/30">
			<svg viewBox="0 0 24 24" fill="none" class="h-5 w-5 text-brand-200" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
			</svg>
		</div>
		<h3 class="text-base font-semibold text-brand-50">
			{url ? (
				<a href={url} target="_blank" rel="noopener noreferrer">
					<span class="absolute -inset-x-4 -inset-y-4 z-10 sm:-inset-x-6 sm:-inset-y-6"></span>
					{title}
				</a>
			) : (
				title
			)}
		</h3>
	</div>
	<p class="mt-3 text-sm text-brand-100/70 line-clamp-3">
		{description}
	</p>
	{tags.length > 0 && (
		<div class="mt-4 flex flex-wrap gap-2">
			{tags.map((tag) => <Badge size="sm">{tag}</Badge>)}
		</div>
	)}
	{url && linkHostname && (
		<p class="mt-4 flex items-center gap-1 text-sm font-medium text-brand-200">
			<svg viewBox="0 0 24 24" fill="none" class="h-4 w-4" stroke="currentColor" stroke-width="1.5">
				<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
			</svg>
			{linkHostname}
		</p>
	)}
</div>
